---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, title_en, description_en, pubDate, updatedDate, author } = Astro.props;
---

<!doctype html>
<html lang="en" data-lang="en">
	<head>
		<BaseHead title={title} description={description} titleEn={title_en} descriptionEn={description_en} />
	</head>
	<body class="bg-black text-white min-h-screen flex flex-col" style="font-family: var(--font-sans);">
		<Header />
		<main class="flex-1 w-full max-w-3xl mx-auto px-6 py-16">
			<article>
				<div class="border-b border-zinc-800 pb-6 mb-10">
					<p
						class="text-xs font-semibold tracking-widest text-zinc-400 uppercase mb-3"
						style="font-family: var(--font-mono);"
					>
						<FormattedDate date={pubDate} />
						{
							updatedDate && (
								<span class="italic text-zinc-500"> · updated <FormattedDate date={updatedDate} /></span>
							)
						}
					</p>
					<h1 class="text-4xl md:text-6xl font-bold tracking-tighter text-white mb-4">
						<span class="lang-kr">{title}</span>
						<span class="lang-en">{title_en ?? title}</span>
					</h1>
					<p
						class="text-xs font-semibold tracking-widest text-white uppercase"
						style="font-family: var(--font-mono);"
					>
						<span class="lang-en">BY</span>
						<span class="lang-kr">작성자</span>
						&nbsp;{author}
					</p>
				</div>
				<div class="prose">
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
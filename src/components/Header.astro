---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header class="w-full border-b border-zinc-800 px-6 py-4 grid grid-cols-3 items-center gap-4">
	<!-- Left: Brand -->
	<div class="flex items-center gap-2">
		<a href="/" class="flex items-center gap-2">
			<img src="/Xizzthesizer_logo.png" alt={SITE_TITLE} class="h-6 w-auto" />
			<span
				class="text-xs font-bold tracking-widest text-white uppercase"
				style="font-family: var(--font-mono);"
			>
				{SITE_TITLE}
			</span>
		</a>
	</div>

	<!-- Center: Nav -->
	<nav class="flex justify-center gap-6">
		<HeaderLink
			href="/"
			class="text-xs font-semibold tracking-widest text-white uppercase hover:text-zinc-400 transition-colors duration-150"
		>
			<span style="font-family: var(--font-mono);">Home</span>
		</HeaderLink>
		<HeaderLink
			href="/blog"
			class="text-xs font-semibold tracking-widest text-white uppercase hover:text-zinc-400 transition-colors duration-150"
		>
			<span style="font-family: var(--font-mono);">/synthesizer</span>
		</HeaderLink>
		<HeaderLink
			href="/about"
			class="text-xs font-semibold tracking-widest text-white uppercase hover:text-zinc-400 transition-colors duration-150"
		>
			<span style="font-family: var(--font-mono);">About</span>
		</HeaderLink>
	</nav>

	<!-- Right: Language toggle -->
	<div class="flex justify-end">
		<button
			id="lang-toggle"
			aria-label="Toggle language"
			class="text-xs font-semibold tracking-widest border border-zinc-600 text-white hover:border-white transition-all duration-150 px-3 py-1 cursor-pointer"
			style="font-family: var(--font-mono);"
		>
			<span class="lang-en">EN → KR</span>
			<span class="lang-kr">KR → EN</span>
		</button>
	</div>
</header>

<script>
	(function () {
		var btn = document.getElementById('lang-toggle');
		if (!btn) return;
		btn.addEventListener('click', function () {
			var html = document.documentElement;
			var current = html.getAttribute('data-lang') || 'en';
			var next = current === 'en' ? 'kr' : 'en';
			html.setAttribute('data-lang', next);
			html.setAttribute('lang', next === 'kr' ? 'ko' : 'en');
			try {
				localStorage.setItem('lang', next);
			} catch (e) {}
			window.dispatchEvent(new CustomEvent('x1zz:langchange', { detail: { lang: next } }));
		});
	})();
</script>
---
import { SITE_AUTHOR } from '../consts';
const today = new Date();
---

<footer
	class="w-full border-t border-zinc-800 px-6 py-5 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-3"
>
	<div class="flex items-center gap-4 text-xs font-semibold text-white" style="font-family: var(--font-mono);">
		<span>xizzthesizer</span>
		<span class="text-zinc-500">|</span>
		<span>&copy; {today.getFullYear()} {SITE_AUTHOR}</span>
	</div>

	<div class="text-xs font-semibold text-white lang-en" style="font-family: var(--font-mono);">
		Designed &amp; built by {SITE_AUTHOR}.
	</div>
	<div class="text-xs font-semibold text-white lang-kr" style="font-family: var(--font-mono);">
		{SITE_AUTHOR}가 디자인하고 만들었습니다.
	</div>
</footer>
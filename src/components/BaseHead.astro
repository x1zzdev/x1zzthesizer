---
// Import the global.css file here so that it is included on
// all pages through the use of the <BaseHead /> component.
import '../styles/global.css';
import { SITE_TITLE } from '../consts';

interface Props {
	title: string;
	description: string;
	titleEn?: string;
	descriptionEn?: string;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const { title, description, titleEn, descriptionEn } = Astro.props;
const safeTitleEn = titleEn ?? null;
const safeDescriptionEn = descriptionEn ?? null;
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="icon" href="/favicon.ico" />
<link rel="sitemap" href="/sitemap-index.xml" />
<link
	rel="alternate"
	type="application/rss+xml"
	title={SITE_TITLE}
	href={new URL('rss.xml', Astro.site)}
/>
<meta name="generator" content={Astro.generator} />

<!-- Fonts: JetBrains Mono + Inter with display=swap -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link
	rel="stylesheet"
	href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;700&display=swap"
/>

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="description" content={description} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content="website" />
<meta property="og:url" content={Astro.url} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />

<!-- ─── Automatic language detection + dynamic title/description swap ──── -->
<script
	define:vars={{
		titleKr: title,
		titleEn: safeTitleEn,
		descriptionKr: description,
		descriptionEn: safeDescriptionEn,
	}}
	is:inline
>
	(function () {
		function applyLang(lang) {
			document.documentElement.setAttribute('data-lang', lang);
			document.documentElement.setAttribute('lang', lang === 'kr' ? 'ko' : 'en');

			var useEn = lang === 'en' && titleEn;
			document.title = useEn ? titleEn : titleKr;

			var useEnDesc = lang === 'en' && descriptionEn;
			var descTag = document.querySelector('meta[name="description"]');
			var ogDescTag = document.querySelector('meta[property="og:description"]');
			var ogTitleTag = document.querySelector('meta[property="og:title"]');
			var finalDesc = useEnDesc ? descriptionEn : descriptionKr;
			if (descTag) descTag.setAttribute('content', finalDesc);
			if (ogDescTag) ogDescTag.setAttribute('content', finalDesc);
			if (ogTitleTag) ogTitleTag.setAttribute('content', useEn ? titleEn : titleKr);
		}

		var stored = null;
		try {
			stored = localStorage.getItem('lang');
		} catch (e) {}

		var lang = stored;
		if (lang !== 'en' && lang !== 'kr') {
			var nav = (navigator.language || navigator.userLanguage || 'en').toLowerCase();
			lang = nav.indexOf('ko') === 0 ? 'kr' : 'en';
		}

		applyLang(lang);

		// Header's language toggle dispatches this event so the tab title / meta
		// description update instantly without a full page reload.
		window.addEventListener('x1zz:langchange', function (e) {
			applyLang(e.detail && e.detail.lang ? e.detail.lang : 'en');
		});
	})();
</script>
---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';
import { getCollection } from 'astro:content';

// Chronological (oldest → newest) order defines the numeric index used in URLs (/blog/1, /blog/2, ...).
const chronological = (await getCollection('blog')).sort(
	(a, b) => a.data.pubDate.valueOf() - b.data.pubDate.valueOf(),
);

// Display newest first, but keep the numeric index tied to chronological position.
const posts = chronological
	.map((post, index) => ({ post, id: index + 1 }))
	.sort((a, b) => b.post.data.pubDate.valueOf() - a.post.data.pubDate.valueOf());
---

<!doctype html>
<html lang="en" data-lang="en">
	<head>
		<BaseHead title={`/synthesizer — ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body class="bg-black text-white min-h-screen flex flex-col" style="font-family: var(--font-sans);">
		<Header />
		<main class="flex-1 w-full max-w-3xl mx-auto px-6 py-16">
			<div class="border-b border-zinc-800 pb-3 mb-8">
				<span
					class="text-xs font-semibold tracking-widest text-white uppercase"
					style="font-family: var(--font-mono);"
				>
					<span class="lang-en">// SYNTHESIZER_INDEX</span>
					<span class="lang-kr">// 신디사이저 인덱스</span>
				</span>
			</div>

			<ul class="space-y-6 list-none m-0 p-0">
				{
					posts.map(({ post, id }) => (
						<li>
							<a
								href={`/blog/${id}/`}
								class="group block border border-zinc-800 p-6 rounded hover:bg-white hover:text-black transition-all duration-150"
							>
								<div class="flex items-center justify-between mb-3">
									<code
										class="text-sm font-bold text-white group-hover:text-black transition-colors duration-150"
										style="font-family: var(--font-mono);"
									>
										/blog/{id}
									</code>
									<span
										class="text-xs font-semibold tracking-widest text-zinc-400 group-hover:text-zinc-800 transition-colors duration-150"
										style="font-family: var(--font-mono);"
									>
										<FormattedDate date={post.data.pubDate} />
									</span>
								</div>
								<h2 class="text-2xl font-bold tracking-tight text-white group-hover:text-black transition-colors duration-150 mb-2">
									{post.data.title}
								</h2>
								<p class="text-sm font-medium leading-relaxed text-white group-hover:text-zinc-800 transition-colors duration-150">
									{post.data.description}
								</p>
							</a>
						</li>
					))
				}
			</ul>
		</main>
		<Footer />
	</body>
</html>